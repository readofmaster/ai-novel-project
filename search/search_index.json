{"config":{"lang":["ja"],"separator":"[\\s\\-\u3000\u3001\u3002\uff0c\uff0e]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"index.html","title":"AI Novel Project","text":"<p>\u3053\u306e\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306f\u3001AI\u3068\u5354\u529b\u3057\u3066\u5c0f\u8aac\u3092\u57f7\u7b46\u30fb\u7ba1\u7406\u3059\u308b\u305f\u3081\u306e\u5b9f\u9a13\u7684\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3067\u3059\u3002 \u3069\u306a\u305f\u3067\u3082\u81ea\u7531\u306b\u95b2\u89a7\u30fb\u5229\u7528\u3067\u304d\u307e\u3059\u3002\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3078\u306e\u8ca2\u732e\u3082\u6b53\u8fce\u3057\u307e\u3059\uff01</p>"},{"location":"index.html#_1","title":"\u30d5\u30a9\u30f3\u30c8\u8a2d\u5b9a","text":"<p>\u660e\u671d\u4f53 \u30b4\u30b7\u30c3\u30af\u4f53</p>"},{"location":"index.html#_2","title":"\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306e\u76ee\u7684","text":"<ul> <li>AI\u3068\u4eba\u9593\u304c\u5354\u8abf\u3057\u3066\u7269\u8a9e\u3092\u5275\u308a\u4e0a\u3052\u308b\u30d7\u30ed\u30bb\u30b9\u3092\u63a2\u7d22\u3059\u308b</li> <li>\u5c0f\u8aac\u306e\u57f7\u7b46\u304b\u3089\u7ba1\u7406\u307e\u3067\u306e\u30ef\u30fc\u30af\u30d5\u30ed\u30fc\u3092\u6700\u9069\u5316\u3059\u308b</li> </ul>"},{"location":"index.html#_3","title":"\u73fe\u5728\u306e\u57f7\u7b46\u8a08\u753b","text":"<p>\u7b2c\u4e00\u5f3e\u3068\u3057\u3066\u3001\u4ee5\u4e0b\u306e\u30da\u30fc\u30b9\u3067\u6587\u7ae0\u4f5c\u6210\u3092\u9032\u3081\u3066\u3044\u307e\u3059\u3002</p> <ul> <li>\u76ee\u6a19\uff1a1\u65e5800\u5b57</li> <li>\u671f\u9593\uff1a\u7d0412\u65e5\u9593\uff08\u5b8c\u4e86\u4e88\u5b9a\uff09</li> <li>\u65b9\u91dd\uff1a\u6700\u77ed\u3067\u5b8c\u9042\u3059\u308b\u3053\u3068\u3092\u76ee\u6307\u3057\u3066\u3044\u307e\u3059\u304c\u3001\u63d0\u793a\u3055\u308c\u305f\u671f\u9593\u306f\u30c4\u30c3\u30b3\u30df\u3084\u6539\u5584\u306b\u3088\u308b\u624b\u623b\u308a\u304c\u306a\u3044\u5834\u5408\u306e\u76ee\u5b89\u3067\u3059\u3002\u5b9f\u969b\u306b\u306f\u9069\u5b9c\u30d5\u30a3\u30fc\u30c9\u30d0\u30c3\u30af\u3092\u53d6\u308a\u5165\u308c\u306a\u304c\u3089\u6539\u5584\u3092\u9032\u3081\u3066\u3044\u304d\u307e\u3059\u3002</li> </ul>"},{"location":"index.html#contributing","title":"\u8ca2\u732e\u306b\u3064\u3044\u3066 (Contributing)","text":"<p>\u3053\u306e\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3092\u3088\u308a\u826f\u304f\u3059\u308b\u305f\u3081\u306e\u63d0\u6848\u3084\u4fee\u6b63\u3092\u6b53\u8fce\u3057\u307e\u3059\u3002 \u6539\u5584\u6848\u3084\u30a2\u30a4\u30c7\u30a2\u304c\u3042\u308b\u5834\u5408\u306f\u3001\u305c\u3072Issue\u3092\u4f5c\u6210\u3057\u305f\u308a\u3001Pull Request\u3092\u9001\u3063\u3066\u304f\u3060\u3055\u3044\u3002</p>"},{"location":"index.html#_4","title":"\u30ef\u30fc\u30af\u30d5\u30ed\u30fc\u3068\u898f\u7d04","text":"<p>\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306e\u30eb\u30fc\u30eb\u306b\u3064\u3044\u3066\u306f\u3001\u4ee5\u4e0b\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002 - docs/rules/NOVEL_WORKFLOW.md</p>"},{"location":"index.html#_5","title":"\u30e9\u30a4\u30bb\u30f3\u30b9","text":"<p>\u3053\u306e\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306f MIT License \u306e\u4e0b\u3067\u516c\u958b\u3055\u308c\u3066\u3044\u307e\u3059\u3002</p>"},{"location":"PLOT.html","title":"\u5c0f\u8aac\uff1a\u30ac\u30fc\u30c7\u30f3\u30fb\u30aa\u30d6\u30fb\u30a8\u30b4 \uff5e\u96a3\u306e\u829d\u751f\u306f\u5730\u7344\u306e\u9999\u308a\u304c\u3059\u308b\uff5e","text":""},{"location":"PLOT.html#_2","title":"\u5168\u4f53\u69cb\u6210","text":"<ul> <li>\u7b2c1\u7ae0\uff1a\u9759\u304b\u306a\u308b\u958b\u6226\uff08\u5e8f\u7ae0\uff09 - \u4f50\u85e4\u304c\u96a3\u4eba\u30fb\u9234\u6728\u306e\u690d\u3048\u305f\u73cd\u3057\u3044\u82b1\u306b\u30e9\u30a4\u30d0\u30eb\u5fc3\u3092\u71c3\u3084\u3059\u3002</li> <li>\u7b2c2\u7ae0\uff1a\u5ead\u3044\u3058\u308a\u306e\u591c\u660e\u3051 - \u4f50\u85e4\u3001\u5bfe\u6297\u3057\u3066\u666f\u89b3\u3092\u6574\u3048\u308b\u3002</li> <li>\u7b2c3\u7ae0\uff1a\u5149\u308b\u690d\u6728\u8972\u6765 - \u9234\u6728\u304c\u767a\u5149\u3059\u308b\u690d\u6728\u3092\u8a2d\u7f6e\u3002</li> <li>\u7b2c4\u7ae0\uff1a\u5ead\u77f3\u306e\u9006\u8972 - \u4f50\u85e4\u3001\u52d5\u304f\u77f3\u50cf\u3092\u914d\u7f6e\u3002</li> <li>\u7b2c5\u7ae0\uff1a\u89b3\u5149\u5730\u5316\u3059\u308b\u4f4f\u5b85\u8857 - \u5ead\u304c\u540d\u6240\u5316\u3057\u3001\u90f5\u4fbf\u914d\u9054\u54e1\u304c\u56f0\u60d1\u3002</li> <li>\u7b2c6\u7ae0\uff1a\u58ee\u5927\u306a\u5ead\u5712\u30d7\u30ed\u30b8\u30a7\u30af\u30c8 - \u4e8c\u4eba\u306e\u5ead\u304c\u5408\u4f53\u3002</li> <li>\u7b2c7\u7ae0\uff1a\u8857\u306e\u8b66\u544a - \u7ba1\u7406\u30b7\u30b9\u30c6\u30e0\u304c\u7570\u5e38\u3092\u691c\u77e5\u3002</li> <li>\u7b2c8\u7ae0\uff1a\u30a8\u30b9\u30ab\u30ec\u30fc\u30b7\u30e7\u30f3\u306e\u9802\u70b9 - \u4f4f\u5b85\u8857\u5168\u4f53\u304c\u5ead\u5712\u5316\u3002</li> <li>\u7b2c9\u7ae0\uff1a\u7a76\u6975\u306e\u5ead\u3078\u306e\u5230\u9054 - \u4e8c\u4eba\u304c\u300c\u4f55\u3082\u3057\u306a\u3044\u300d\u5883\u5730\u306b\u3002</li> <li>\u7b2c10\u7ae0\uff1a\u8352\u91ce\u306e\u4f4f\u5b85\u8857\uff08\u7d50\u672b\uff09 - \u5b8c\u74a7\u306a\u7ba1\u7406\u793e\u4f1a\u306b\u73fe\u308c\u305f\u7570\u8cea\u306a\u539f\u3063\u3071\u3002</li> </ul>"},{"location":"PROGRESS.html","title":"\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u9032\u6357\u72b6\u6cc1","text":""},{"location":"PROGRESS.html#_2","title":"\u5168\u4f53\u9032\u6357","text":"<p>70% \u5b8c\u4e86 (5/10 \u7ae0)</p>"},{"location":"PROGRESS.html#_3","title":"\u73fe\u5728\u306e\u30b9\u30c6\u30fc\u30bf\u30b9","text":"<ul> <li>\u57f7\u7b46\u4e2d: \u7b2c8\u7ae0\u306e\u6e96\u5099\u4e2d</li> </ul>"},{"location":"PROGRESS.html#_4","title":"\u5b8c\u4e86\u3057\u305f\u30de\u30a4\u30eb\u30b9\u30c8\u30fc\u30f3","text":"<ul> <li>[x] \u7b2c7\u7ae0 \u57f7\u7b46\u30fb\u6821\u95b2\u30fb\u7d71\u5408\u5b8c\u4e86</li> <li>[x] \u7b2c6\u7ae0 \u57f7\u7b46\u30fb\u6821\u95b2\u30fb\u7d71\u5408\u5b8c\u4e86</li> <li>[x] \u7b2c5\u7ae0 \u57f7\u7b46\u30fb\u6821\u95b2\u30fb\u7d71\u5408\u5b8c\u4e86</li> <li>[x] \u7b2c4\u7ae0 \u57f7\u7b46\u30fb\u6821\u95b2\u30fb\u7d71\u5408\u5b8c\u4e86</li> <li>[x] \u7b2c3\u7ae0 \u57f7\u7b46\u30fb\u6821\u95b2\u30fb\u7d71\u5408\u5b8c\u4e86</li> <li>[x] \u7b2c2\u7ae0 \u57f7\u7b46\u30fb\u6821\u95b2\u30fb\u7d71\u5408\u5b8c\u4e86</li> <li>[x] \u7b2c1\u7ae0 \u57f7\u7b46\u30fb\u6821\u95b2\u30fb\u7d71\u5408\u5b8c\u4e86</li> <li>[x] \u30d7\u30ed\u30c3\u30c8\u4f5c\u6210</li> </ul>"},{"location":"PROGRESS.html#github","title":"GitHub \u7d71\u8a08","text":"<ul> <li>PR\u6570\u3000\u30aa\u30fc\u30d7\u30f3 0 / \u30af\u30ed\u30fc\u30ba 7</li> <li>Issue\u6570\u3000\u30aa\u30fc\u30d7\u30f3 1 / \u30af\u30ed\u30fc\u30ba 3</li> </ul>"},{"location":"novel/index.html","title":"\u5c0f\u8aac\u4e00\u89a7","text":"<p>\u5404\u7ae0\u3078\u306f\u3053\u3061\u3089\u304b\u3089\u79fb\u52d5\u3067\u304d\u307e\u3059\u3002</p> <ul> <li> <p>\u767b\u5834\u4eba\u7269\u7d39\u4ecb</p> </li> <li> <p>\u7b2c1\u7ae0\uff1a\u9759\u304b\u306a\u308b\u958b\u6226</p> </li> <li>\u7b2c2\u7ae0\uff1a\u5ead\u3044\u3058\u308a\u306e\u591c\u660e\u3051</li> <li> <p>\u7b2c3\u7ae0\uff1a\u5149\u308b\u690d\u6728\u8972\u6765</p> </li> <li> <p>\u7b2c4\u7ae0\uff1a\u5ead\u77f3\u306e\u9006\u8972</p> </li> <li>\u7b2c5\u7ae0\uff1a\u5ead\u5148\u306f\u30ef\u30f3\u30c0\u30fc\u30e9\u30f3\u30c9</li> <li>\u7b2c6\u7ae0\uff1a\u5883\u754c\u7dda\u3001\u6d88\u6ec5\u306e\u304a\u77e5\u3089\u305b</li> <li>\u7b2c7\u7ae0\uff1a\u81ea\u6cbb\u4f1a\u3001\u6fc0\u6012\u306e\u8d64\u4fe1\u53f7</li> </ul>"},{"location":"novel/chapter1.html","title":"\u7b2c1\u7ae0\uff1a\u9759\u304b\u306a\u308b\u958b\u6226","text":"<p>\u4f50\u85e4\u304c\u611b\u3059\u308b\u5ead\u306b\u306f\u3001\u3053\u308c\u307e\u3067\u300c\u8abf\u548c\u300d\u3068\u3044\u3046\u540d\u306e\u5e73\u548c\u304c\u6d41\u308c\u3066\u3044\u305f\u3002\u5b63\u7bc0\u306e\u82b1\u3092\u690d\u3048\u3001\u6bce\u9031\u829d\u3092\u5208\u308a\u3001\u96a3\u5bb6\u3068\u306e\u5883\u754c\u7dda\u306b\u306f\u63a7\u3048\u3081\u306a\u30e9\u30c6\u30a3\u30b9\u3092\u7f6e\u304f\u3002\u305d\u308c\u3060\u3051\u3067\u5341\u5206\u3001\u7f8e\u3057\u3044\u4f4f\u5b85\u8857\u306e\u666f\u89b3\u306f\u4fdd\u305f\u308c\u3066\u3044\u305f\u306f\u305a\u3060\u3063\u305f\u3002</p> <p>\u3042\u3044\u3064\u2015\u2015\u96a3\u306e\u9234\u6728\u304c\u3001\u3042\u306e\u300c\u5947\u5999\u306a\u9752\u3044\u82b1\u300d\u3092\u9023\u308c\u5e30\u3063\u3066\u304f\u308b\u307e\u3067\u306f\u3002</p> <p>\u571f\u66dc\u306e\u671d\u3001\u30b3\u30fc\u30d2\u30fc\u7247\u624b\u306b\u7e01\u5074\u3078\u51fa\u305f\u4f50\u85e4\u306f\u3001\u601d\u308f\u305a\u5674\u304d\u51fa\u3057\u305d\u3046\u306b\u306a\u3063\u305f\u3002\u9234\u6728\u306e\u5ead\u306e\u4e2d\u592e\u306b\u3001\u898b\u305f\u3053\u3068\u3082\u306a\u3044\u54c1\u7a2e\u304c\u93ae\u5ea7\u3057\u3066\u3044\u305f\u306e\u3060\u3002\u82b1\u5f01\u306f\u6bd2\u3005\u3057\u3044\u307b\u3069\u306b\u9bae\u3084\u304b\u306a\u30cd\u30aa\u30f3\u30d6\u30eb\u30fc\u3067\u3001\u3042\u308d\u3046\u3053\u3068\u304b\u3001\u65e5\u5dee\u3057\u3092\u6d74\u3073\u308b\u305f\u3073\u306b\u5fae\u304b\u306b\u91d1\u5c5e\u7684\u306a\u5149\u6ca2\u3092\u653e\u3063\u3066\u3044\u308b\u3002</p> <p>\u300c\u2026\u2026\u306a\u3093\u3060\u3001\u3042\u308a\u3083\u300d</p> <p>\u4f50\u85e4\u306f\u76ee\u3092\u3053\u3059\u3063\u305f\u3002\u5408\u6210\u7740\u8272\u6599\u3067\u67d3\u3081\u305f\u306e\u304b\u3068\u7591\u3046\u30ec\u30d9\u30eb\u3060\u3002\u3057\u304b\u3082\u3001\u305d\u306e\u82b1\u306f\u4e0d\u81ea\u7136\u306a\u307e\u3067\u306b\u80cc\u304c\u9ad8\u304f\u3001\u4f50\u85e4\u306e\u5ead\u3092\u7765\u7768\uff08\u3078\u3044\u3052\u3044\uff09\u3059\u308b\u3088\u3046\u306b\u54b2\u304d\u8a87\u3063\u3066\u3044\u308b\u3002\u96a3\u5bb6\u306e\u5ead\u306e\u8cea\u611f\u304c\u3001\u4e00\u77ac\u306b\u3057\u3066\u305d\u3053\u3060\u3051\u7570\u754c\u306e\u305d\u308c\u306b\u5857\u308a\u66ff\u3048\u3089\u308c\u305f\u3088\u3046\u306a\u611f\u899a\u3002</p> <p>\u9234\u6728\u306f\u3001\u30b8\u30e7\u30a6\u30ed\u3092\u7247\u624b\u306b\u6e80\u8db3\u3052\u306a\u7b11\u307f\u3092\u6d6e\u304b\u3079\u3066\u3044\u305f\u3002\u3084\u3064\u306f\u4f50\u85e4\u306e\u8996\u7dda\u306b\u6c17\u3065\u304f\u3068\u3001\u308f\u3056\u3068\u3089\u3057\u304f\u82b1\u3092\u611b\u3067\u308b\u3088\u3046\u306a\u4ed5\u8349\u3092\u3057\u3001\u300c\u304a\u306f\u3088\u3046\u3001\u4f50\u85e4\u3055\u3093\u3002\u3053\u306e\u30d6\u30eb\u30fc\u30fb\u30a4\u30f3\u30d5\u30a7\u30eb\u30ce\u3001\u306a\u304b\u306a\u304b\u3067\u3057\u3087\u3046\uff1f\u300d\u3068\u723d\u3084\u304b\u306b\u6328\u62f6\u3057\u3066\u304f\u308b\u3002</p> <p>\u30d6\u30eb\u30fc\u30fb\u30a4\u30f3\u30d5\u30a7\u30eb\u30ce\u3002\u76f4\u8a33\u3059\u308c\u3070\u300e\u9752\u3044\u5730\u7344\u300f\u3060\u3002\u306a\u3093\u3066\u4e0d\u5409\u3067\u3001\u306a\u3093\u3066\u6311\u767a\u7684\u306a\u30cd\u30fc\u30df\u30f3\u30b0\u3060\u3002</p> <p>\u4f50\u85e4\u306e\u5fc3\u306e\u4e2d\u3067\u3001\u4f55\u304b\u304c\u30d1\u30c1\u30f3\u3068\u5f3e\u3051\u305f\u3002\u3053\u308c\u307e\u3067\u57f9\u3063\u3066\u304d\u305f\u300c\u5468\u56f2\u3068\u306e\u8abf\u548c\u300d\u3068\u3044\u3046\u7f8e\u5fb3\u304c\u3001\u9234\u6728\u306e\u690d\u3048\u305f\u7570\u5f62\u306e\u690d\u7269\u306b\u3088\u3063\u3066\u771f\u3063\u5411\u304b\u3089\u5426\u5b9a\u3055\u308c\u305f\u306e\u3060\u3002\u3053\u308c\u306f\u8da3\u5473\u306e\u554f\u984c\u3067\u306f\u306a\u3044\u3002\u751f\u5b58\u7af6\u4e89\u3060\u3002</p> <p>\u300c\u2026\u2026\u3042\u3042\u3001\u78ba\u304b\u306b\u3002\u76ee\u304c\u6f70\u308c\u305d\u3046\u306a\u304f\u3089\u3044\u3001\u500b\u6027\u7684\u3067\u300e\u9762\u767d\u3044\u300f\u5ead\u3060\u306d\u300d</p> <p>\u4f50\u85e4\u306f\u5fc5\u6b7b\u3067\u5f15\u304d\u3064\u308b\u982c\u3092\u96a0\u3057\u306a\u304c\u3089\u3001\u305d\u3046\u8a00\u3044\u8fd4\u3057\u305f\u3002\u305d\u306e\u77ac\u9593\u3001\u4f50\u85e4\u306e\u4e2d\u3067\u9759\u304b\u306a\u958b\u6226\u306e\u30b4\u30f3\u30b0\u304c\u9cf4\u308a\u97ff\u304f\u3002\u5e73\u548c\u306a\u9031\u672b\u304c\u3001\u7d42\u308f\u308a\u3092\u544a\u3052\u305f\u3002</p>"},{"location":"novel/chapter2.html","title":"\u7b2c2\u7ae0\uff1a\u5ead\u3044\u3058\u308a\u306e\u591c\u660e\u3051","text":"<p>\u300c\u9234\u6728\u3081\u3001\u3084\u308a\u3084\u304c\u3063\u305f\u306a\u300d</p> <p>\u671d\u713c\u3051\u306e\u4e2d\u3001\u4f50\u85e4\u306f\u30b3\u30fc\u30d2\u30fc\u30ab\u30c3\u30d7\u3092\u63e1\u308a\u3057\u3081\u305f\u307e\u307e\u3001\u7a93\u306e\u5916\u306b\u91d8\u4ed8\u3051\u306b\u306a\u3063\u305f\u3002\u96a3\u5bb6\u3068\u306e\u5883\u754c\u7dda\u306b\u7f6e\u304b\u308c\u305f\u9234\u6728\u306e\u5ead\u304c\u3001\u6628\u65e5\u307e\u3067\u3068\u306f\u6bd4\u3079\u7269\u306b\u306a\u3089\u306a\u3044\u307b\u3069\u6d17\u7df4\u3055\u308c\u3066\u3044\u308b\u3002\u6628\u65e5\u307e\u3067\u305f\u3060\u306e\u8336\u8272\u3044\u571f\u3060\u3063\u305f\u5834\u6240\u306b\u3001\u5e7e\u4f55\u5b66\u6a21\u69d8\u306e\u7802\u5229\u304c\u6577\u304b\u308c\u3001\u3055\u3089\u306b\u306f\u7570\u56fd\u60c5\u7dd2\u3042\u3075\u308c\u308b\u5947\u5999\u306a\u5f62\u306e\u4f4e\u6728\u304c\u3001\u307e\u308b\u3067\u8a87\u3089\u3057\u3052\u306b\u80cc\u7b4b\u3092\u4f38\u3070\u3057\u3066\u3044\u305f\u3002</p> <p>\u300c\u666f\u89b3\u6574\u5099\u306a\u3089\u3001\u4ffa\u3060\u3063\u3066\u8ca0\u3051\u3066\u3044\u3089\u308c\u306a\u3044\u2026\u2026\uff01\u300d</p> <p>\u4f50\u85e4\u306e\u95d8\u5fd7\u306b\u706b\u304c\u3064\u3044\u305f\u3002\u5f7c\u306f\u6025\u3044\u3067\u30db\u30fc\u30e0\u30bb\u30f3\u30bf\u30fc\u3078\u76f4\u884c\u3057\u3001\u3042\u308a\u3063\u305f\u3051\u306e\u5712\u82b8\u7528\u30ec\u30f3\u30ac\u3068\u3001\u6700\u9ad8\u7d1a\u306e\u829d\u751f\u306e\u7a2e\u3092\u8cb7\u3044\u5360\u3081\u305f\u3002\u5e30\u5b85\u3059\u308b\u306a\u308a\u3001\u5f7c\u306f\u5ead\u3078\u98db\u3073\u51fa\u3059\u3002\u30b9\u30b3\u30c3\u30d7\u3092\u632f\u308b\u3046\u8155\u306b\u529b\u304c\u3053\u3082\u308b\u3002\u5358\u306a\u308b\u8349\u3080\u3057\u308a\u3067\u306f\u306a\u3044\u3002\u3053\u308c\u306f\u9632\u885b\u6226\u3067\u3042\u308a\u3001\u5a01\u4fe1\u3092\u304b\u3051\u305f\u30c6\u30ea\u30c8\u30ea\u30fc\u4e89\u3044\u3060\u3002</p> <p>\u4f50\u85e4\u306f\u5ead\u306e\u89d2\u306b\u3001\u30cd\u30c3\u30c8\u901a\u8ca9\u3067\u885d\u52d5\u8cb7\u3044\u3057\u305f\u300c\u5317\u6b27\u98a8\u306e\u30ac\u30fc\u30c7\u30f3\u30e9\u30a4\u30c8\u300d\u3092\u7a81\u304d\u7acb\u3066\u305f\u3002\u9234\u6728\u306e\u4f4e\u6728\u304c\u6301\u3064\u81ea\u7136\u306e\u7f8e\u3057\u3055\u306b\u5bfe\u3057\u3001\u3053\u3061\u3089\u306f\u7121\u6a5f\u8cea\u306a\u6587\u660e\u306e\u5149\u3067\u5bfe\u6297\u3059\u308b\u6226\u7565\u3060\u3002\u3055\u3089\u306b\u3001\u5ead\u306e\u7e01\u53d6\u308a\u306b\u306f\u3001\u4e00\u3064\u4e00\u3064\u4e01\u5be7\u306b\u78e8\u304d\u4e0a\u3052\u305f\u767d\u3044\u7389\u7802\u5229\u3092\u914d\u7f6e\u3059\u308b\u3002\u305d\u306e\u59ff\u306f\u3001\u307e\u308b\u3067\u9663\u5730\u3092\u5e83\u3052\u308b\u5c06\u8ecd\u306e\u3088\u3046\u3060\u3063\u305f\u3002</p> <p>\u6570\u6642\u9593\u5f8c\u3001\u6c57\u3060\u304f\u306b\u306a\u3063\u305f\u4f50\u85e4\u304c\u8170\u3092\u4f38\u3070\u3059\u3068\u3001\u3061\u3087\u3046\u3069\u96a3\u304b\u3089\u3082\u300c\u3075\u3045\u300d\u3068\u3044\u3046\u5410\u606f\u304c\u805e\u3053\u3048\u305f\u3002\u898b\u308c\u3070\u3001\u9234\u6728\u3082\u307e\u305f\u6ce5\u3060\u3089\u3051\u306e\u9854\u3067\u3001\u3053\u3061\u3089\u3092\u3058\u3063\u3068\u898b\u3064\u3081\u3066\u3044\u308b\u3002\u4e8c\u4eba\u306e\u8996\u7dda\u304c\u7a7a\u4e2d\u3067\u4ea4\u5dee\u3057\u305f\u3002</p> <p>\u300c\u3044\u3044\u8da3\u5473\u3067\u3059\u306d\u3001\u4f50\u85e4\u3055\u3093\u300d \u300c\u305d\u3061\u3089\u3082\u3001\u306a\u304b\u306a\u304b\u2026\u2026\u6d3e\u624b\u306a\u4f4e\u6728\u3067\u3059\u306d\u300d</p> <p>\u304a\u4e92\u3044\u306b\u5f15\u304d\u3064\u3063\u305f\u7b11\u9854\u3092\u6d6e\u304b\u3079\u308b\u3002\u4f50\u85e4\u306e\u5fc3\u306e\u4e2d\u306b\u306f\u3001\u52dd\u5229\u306e\u78ba\u4fe1\u3068\u3001\u6b21\u306a\u308b\u4e00\u624b\u3092\u3069\u3046\u6253\u3064\u304b\u3068\u3044\u3046\u65b0\u305f\u306a\u7b56\u8b00\u304c\u6e26\u5dfb\u3044\u3066\u3044\u305f\u3002\u660e\u65e5\u306e\u671d\u3001\u3053\u306e\u5ead\u306f\u307e\u305f\u5225\u306e\u59ff\u306b\u751f\u307e\u308c\u5909\u308f\u3063\u3066\u3044\u308b\u306f\u305a\u3060\u3002 \u9759\u304b\u306a\u4f4f\u5b85\u8857\u306e\u671d\u306b\u3001\u5712\u82b8\u3068\u3044\u3046\u540d\u306e\u9759\u304b\u306a\u308b\u72c2\u9a12\u66f2\uff08\u30e9\u30d7\u30bd\u30c7\u30a3\uff09\u304c\u5e55\u3092\u958b\u3051\u305f\u3002</p>"},{"location":"novel/chapter3.html","title":"\u7b2c3\u7ae0\uff1a\u5149\u308b\u690d\u6728\u8972\u6765","text":"<p>\u571f\u66dc\u65e5\u306e\u671d\u3001\u30ab\u30fc\u30c6\u30f3\u3092\u958b\u3051\u305f\u4f50\u85e4\u306f\u7d76\u53e5\u3057\u305f\u3002</p> <p>\u300c\u2026\u2026\u306a\u3093\u3060\u3001\u3042\u308c\u306f\u300d</p> <p>\u96a3\u5bb6\u30fb\u9234\u6728\u306e\u5ead\u306e\u5149\u666f\u306f\u3001\u3082\u306f\u3084\u5712\u82b8\u306e\u57df\u3092\u8d85\u3048\u3066\u3044\u305f\u3002\u305d\u3053\u306b\u306f\u3001\u771f\u663c\u3060\u3068\u3044\u3046\u306e\u306b\u602a\u3057\u3052\u306a\u9752\u767d\u3044\u71d0\u5149\u3092\u653e\u3064\u3001\u30b7\u30c0\u690d\u7269\u306e\u3088\u3046\u306a\u4f55\u304b\u304c\u93ae\u5ea7\u3057\u3066\u3044\u305f\u306e\u3060\u3002\u8449\u306e\u4e00\u679a\u4e00\u679a\u304c\u3001\u307e\u308b\u3067\u547c\u5438\u3059\u308b\u3088\u3046\u306b\u660e\u6ec5\u3057\u3066\u3044\u308b\u3002</p> <p>\u300c\u4f50\u85e4\u3055\u3093\u3001\u304a\u306f\u3088\u3046\uff01 \u3044\u3044\u5929\u6c17\u3067\u3059\u306d\u3047\u300d</p> <p>\u9234\u6728\u304c\u9f3b\u6b4c\u307e\u3058\u308a\u306b\u30b8\u30e7\u30a6\u30ed\u3092\u7247\u624b\u306b\u73fe\u308c\u305f\u3002\u305d\u306e\u9854\u306b\u306f\u3001\u6628\u65e5\u307e\u3067\u306e\u300c\u3054\u8fd1\u6240\u4ed8\u304d\u5408\u3044\u300d\u306e\u7a4f\u3084\u304b\u3055\u306f\u306a\u3044\u3002\u3042\u308b\u306e\u306f\u3001\u65b0\u5175\u5668\u3092\u6226\u5834\u306b\u6301\u3061\u8fbc\u3093\u3060\u53f8\u4ee4\u5b98\u306e\u3088\u3046\u306a\u4e0d\u6575\u306a\u7b11\u307f\u3060\u3002</p> <p>\u300c\u9234\u6728\u3055\u3093\u3001\u305d\u306e\u2026\u2026\u690d\u7269\u306f\u4e00\u4f53\u2026\u2026\u300d \u300c\u3042\u3042\u3001\u3053\u308c\uff1f \u591c\u306b\u306a\u308b\u3068\u3082\u3063\u3068\u7dba\u9e97\u3067\u3059\u3088\u3002\u8fd1\u6240\u306e\u5712\u82b8\u5e97\u3067\u300e\u5e0c\u5c11\u7a2e\u300f\u3068\u3057\u3066\u88cf\u30eb\u30fc\u30c8\u304b\u3089\u4ed5\u5165\u308c\u305f\u3093\u3067\u3059\u3002\u5b66\u540d\u306f\u77e5\u308a\u307e\u305b\u3093\u304c\u3001\u3069\u3046\u3084\u3089\u96fb\u6c17\u30a6\u30ca\u30ae\u306e\u907a\u4f1d\u5b50\u3068\u4ea4\u914d\u3057\u3066\u308b\u3089\u3057\u3044\u3067\u3059\u3088\u300d</p> <p>\u300c\u4ea4\u914d\u306e\u30d9\u30af\u30c8\u30eb\u304c\u9593\u9055\u3063\u3066\u308b\u3060\u308d\uff01\u300d</p> <p>\u4f50\u85e4\u306e\u30c4\u30c3\u30b3\u30df\u3082\u865a\u3057\u304f\u3001\u305d\u306e\u690d\u6728\u306f\u300c\u30d6\u30a5\u30f3\u2026\u2026\u300d\u3068\u91cd\u4f4e\u97f3\u3092\u97ff\u304b\u305b\u305f\u3002\u8fd1\u96a3\u306e\u5bb6\u3005\u304b\u3089\u3001\u72ac\u304c\u30ad\u30e3\u30f3\u30ad\u30e3\u30f3\u3068\u9a12\u304e\u51fa\u3057\u3001\u671d\u306e\u9759\u5bc2\u306f\u5b8c\u5168\u306b\u6253\u3061\u7815\u304b\u308c\u305f\u3002</p> <p>\u9234\u6728\u306e\u5ead\u304c\u3001SF\u6620\u753b\u306e\u30bb\u30c3\u30c8\u306e\u3088\u3046\u306b\u8f1d\u304d\u3092\u5897\u3057\u3066\u3044\u304f\u3002\u5bfe\u3059\u308b\u4f50\u85e4\u306e\u5ead\u306b\u3042\u308b\u306e\u306f\u3001\u6628\u65e5\u30db\u30fc\u30e0\u30bb\u30f3\u30bf\u30fc\u3067\u8cb7\u3063\u305f\u3070\u304b\u308a\u306e\u3001\u3054\u304f\u666e\u901a\u306e\u4f4e\u6728\u3060\u3002\u4f50\u85e4\u306f\u62f3\u3092\u63e1\u308a\u3057\u3081\u305f\u3002\u305f\u3060\u306e\u82b1\u58c7\u3092\u4f5c\u308b\u3064\u3082\u308a\u3060\u3063\u305f\u306f\u305a\u304c\u3001\u3044\u3064\u306e\u9593\u306b\u304b\u3053\u308c\u306f\u3001\u5e73\u7a4f\u306a\u4f4f\u5b85\u8857\u3092\u821e\u53f0\u306b\u3057\u305f\u300c\u751f\u5b58\u7af6\u4e89\u300d\u3078\u3068\u5909\u8c8c\u3057\u3066\u3044\u305f\u3002</p> <p>\u300c\u898b\u3066\u3066\u304f\u3060\u3055\u3044\u3088\u3001\u4f50\u85e4\u3055\u3093\u3002\u660e\u65e5\u306e\u591c\u306b\u306f\u3001\u3053\u306e\u5ead\u304c\u8857\u306e\u706f\u53f0\u306b\u306a\u308a\u307e\u3059\u304b\u3089\u300d</p> <p>\u9234\u6728\u306e\u5ba3\u8a00\u3068\u540c\u6642\u306b\u3001\u690d\u6728\u304c\u4e00\u6bb5\u3068\u5f37\u304f\u660e\u6ec5\u3057\u305f\u3002\u4f50\u85e4\u306e\u5fc3\u306b\u3001\u95d8\u4e89\u306e\u706b\u304c\u706f\u308b\u3002</p> <p>\uff08\u8ca0\u3051\u3066\u305f\u307e\u308b\u304b\u2026\u2026\uff09</p> <p>\u4f50\u85e4\u306f\u6025\u3044\u3067\u30b9\u30de\u30db\u3092\u624b\u306b\u53d6\u308a\u3001\u602a\u3057\u3044\u5712\u82b8\u30ab\u30bf\u30ed\u30b0\u306e\u30da\u30fc\u30b8\u3092\u3081\u304f\u308a\u59cb\u3081\u305f\u3002</p>"},{"location":"novel/chapter4.html","title":"\u7b2c4\u7ae0\uff1a\u5ead\u77f3\u306e\u9006\u8972","text":"<p>\u591c\u7a7a\u306b\u6d6e\u304b\u3076\u306e\u306f\u3001\u9234\u6728\u306e\u5ead\u304b\u3089\u653e\u305f\u308c\u308b\u9752\u767d\u3044\u767a\u5149\u690d\u7269\u306e\u602a\u5149\u7dda\u3067\u306f\u306a\u3044\u3002\u4f50\u85e4\u306e\u5ead\u3067\u3001\u91cd\u3005\u3057\u304f\u3082\u8efd\u3084\u304b\u306b\u8e8d\u52d5\u3059\u308b\u5f71\u3060\u3002</p> <p>\u300c\u2026\u2026\u52d5\u3044\u305f\u300d</p> <p>\u4f50\u85e4\u306f\u9707\u3048\u308b\u624b\u3067\u61d0\u4e2d\u96fb\u706f\u3092\u63e1\u308a\u3057\u3081\u3001\u7a93\u304b\u3089\u5ead\u3092\u898b\u4e0b\u308d\u3057\u3066\u3044\u305f\u3002\u5f7c\u304c\u6700\u65b0\u306e\u5712\u82b8\u30b7\u30e7\u30c3\u30d7\u3067\u3001\u300c\u610f\u5fd7\u3092\u6301\u3064\u77f3\u5ead\u30ad\u30c3\u30c8\u300d\u3068\u3057\u3066\u8cfc\u5165\u3057\u305f\u9ed2\u3044\u5fa1\u5f71\u77f3\u306e\u7fa4\u308c\u3002\u5f53\u521d\u306f\u305f\u3060\u306e\u7f6e\u7269\u3060\u3068\u601d\u3063\u3066\u3044\u305f\u304c\u3001\u9234\u6728\u306e\u5149\u308b\u690d\u6728\u304c\u591c\u306a\u591c\u306a\u5ead\u3092\u7167\u3089\u3057\u59cb\u3081\u3066\u304b\u3089\u3001\u72b6\u6cc1\u306f\u4e00\u5909\u3057\u305f\u3002</p> <p>\u77f3\u305f\u3061\u306f\u3001\u9234\u6728\u306e\u690d\u6728\u304c\u591c\u306a\u591c\u306a\u653e\u51fa\u3059\u308b\u8b0e\u306e\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u5438\u53ce\u3057\u3001\u6df1\u591c\u4e8c\u6642\u3092\u56de\u308b\u3068\u6c7a\u307e\u3063\u3066\u300c\u884c\u9032\u300d\u3092\u59cb\u3081\u308b\u306e\u3060\u3002\u305d\u308c\u306f\u307e\u308b\u3067\u3001\u793e\u4ea4\u30c0\u30f3\u30b9\u306e\u7df4\u7fd2\u3092\u3057\u3066\u3044\u308b\u304b\u306e\u3088\u3046\u306b\u512a\u96c5\u3067\u3001\u304b\u3064\u653b\u6483\u7684\u3060\u3063\u305f\u3002</p> <p>\u300c\u3044\u3044\u304b\u3001\u914d\u7f6e\u306f\u5b8c\u74a7\u3060\u3002\u3042\u3044\u3064\u304c\u3053\u3063\u3061\u306b\u5149\u7dda\u3092\u5411\u3051\u3066\u304f\u308b\u306a\u3089\u3001\u3053\u3063\u3061\u306f\u7269\u7406\u7684\u306a\u5727\u3067\u5bfe\u6297\u3059\u308b\uff01\u300d</p> <p>\u4f50\u85e4\u304c\u5ead\u306e\u30b9\u30a4\u30c3\u30c1\u3092\u5165\u308c\u308b\u3068\u3001\u5ead\u77f3\u305f\u3061\u304c\u4e00\u6589\u306b\u9234\u6728\u306e\u6577\u5730\u3068\u306e\u5883\u754c\u7dda\u3078\u3068\u306a\u3060\u308c\u8fbc\u3080\u3002\u9234\u6728\u306e\u690d\u6728\u304c\u653e\u3064\u300c\u30d6\u30fc\u30f3\u300d\u3068\u3044\u3046\u96fb\u5b50\u97f3\u306e\u3088\u3046\u306a\u7fbd\u97f3\u306b\u5bfe\u3057\u3001\u5ead\u77f3\u305f\u3061\u306f\u300c\u30b3\u30c4\u3001\u30b3\u30c4\u3001\u30b3\u30c4\u300d\u3068\u91cd\u539a\u306a\u30ea\u30ba\u30e0\u3092\u523b\u307f\u3001\u5b8c\u74a7\u306a\u30d5\u30a9\u30fc\u30e1\u30fc\u30b7\u30e7\u30f3\u3067\u9632\u58c1\u3092\u7bc9\u304d\u4e0a\u3052\u305f\u3002</p> <p>\u7fcc\u671d\u3002\u30ab\u30fc\u30c6\u30f3\u3092\u958b\u3051\u305f\u4f50\u85e4\u306f\u3001\u601d\u308f\u305a\u30b3\u30fc\u30d2\u30fc\u3092\u5439\u304d\u51fa\u3057\u305f\u3002 \u6628\u6669\u306e\u884c\u9032\u306e\u7d50\u679c\u3001\u4f50\u85e4\u306e\u5ead\u77f3\u305f\u3061\u306f\u3001\u9234\u6728\u306e\u5149\u308b\u690d\u6728\u3092\u5b8c\u5168\u306b\u5305\u56f2\u3057\u3001\u3055\u3089\u306b\u305d\u308c\u3089\u3092\u300c\u82b1\u3073\u3089\u300d\u306e\u3088\u3046\u306b\u898b\u7acb\u3066\u3066\u3001\u5de8\u5927\u306a\u300c\u82b1\u306e\u5f62\u3092\u3057\u305f\u77f3\u306e\u30aa\u30d6\u30b8\u30a7\u300d\u3078\u3068\u518d\u69cb\u7bc9\u3057\u3066\u3044\u305f\u306e\u3060\u3002</p> <p>\u305d\u3053\u3078\u3001\u9234\u6728\u304c\u5bdd\u7656\u306e\u3064\u3044\u305f\u982d\u3067\u73fe\u308c\u308b\u3002 \u300c\u304a\u3044\u3001\u4f50\u85e4\u3055\u3093\u3002\u3046\u3061\u306e\u690d\u6728\u304c\u2026\u2026\u52dd\u624b\u306b\u77f3\u3068\u5408\u4f53\u3057\u3066\u3001\u5999\u306a\u30c0\u30f3\u30b9\u3092\u8e0a\u3063\u3066\u308b\u3093\u3060\u304c\uff1f\u300d \u300c\u77e5\u3089\u3093\u3088\u3002\u2026\u2026\u3044\u3084\u3001\u3053\u308c\u306f\u300e\u5ead\u306e\u610f\u601d\u300f\u3060\u3002\u304a\u4e92\u3044\u306e\u5ead\u304c\u3001\u52dd\u624b\u306b\u9ad8\u3081\u5408\u3063\u3066\u3044\u308b\u306e\u3055\u300d</p> <p>\u4f50\u85e4\u306f\u8a87\u3089\u3057\u3052\u306b\u80f8\u3092\u5f35\u3063\u305f\u3002\u9234\u6728\u306f\u5446\u308c\u306a\u304c\u3089\u3082\u3001\u305d\u306e\u77f3\u3068\u690d\u7269\u304c\u7e54\u308a\u306a\u3059\u5947\u602a\u306a\u9020\u5f62\u7f8e\u3092\u3001\u3069\u3053\u304b\u611f\u5fc3\u3057\u305f\u3088\u3046\u306a\u76ee\u3067\u773a\u3081\u3066\u3044\u305f\u3002\u4f4f\u5b85\u8857\u306e\u5e73\u548c\u306f\u3001\u4eca\u3084\u5b8c\u5168\u306b\u72c2\u3063\u305f\u82b8\u8853\u306e\u9818\u57df\u306b\u7a81\u5165\u3057\u3066\u3044\u305f\u3002</p>"},{"location":"novel/chapter5.html","title":"\u7b2c5\u7ae0\uff1a\u5ead\u5148\u306f\u30ef\u30f3\u30c0\u30fc\u30e9\u30f3\u30c9","text":"<p>\u5e73\u7a4f\u3060\u3063\u305f\u306f\u305a\u306e\u4f4f\u5b85\u8857\u306b\u3001\u7570\u5909\u304c\u8d77\u304d\u305f\u306e\u306f\u706b\u66dc\u65e5\u306e\u671d\u3060\u3063\u305f\u3002</p> <p>\u4f50\u85e4\u304c\u5ead\u306e\u300c\u52d5\u304f\u77f3\u50cf\uff08\u6628\u591c\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8\u3057\u305f\u3070\u304b\u308a\u306e\u6700\u65b0\u578b\uff09\u300d\u306b\u7d66\u6cb9\u3092\u3057\u3066\u3044\u308b\u3068\u3001\u67f5\u8d8a\u3057\u306b\u30ab\u30e1\u30e9\u3092\u69cb\u3048\u305f\u96c6\u56e3\u304c\u901a\u308a\u904e\u304e\u3066\u3044\u304f\u3002\u5f7c\u3089\u306f\u30b9\u30de\u30db\u3092\u63b2\u3052\u3001\u9234\u6728\u306e\u300c\u767a\u5149\u3059\u308b\u690d\u6728\u300d\u3068\u4f50\u85e4\u306e\u300c\u52d5\u304f\u77f3\u50cf\u300d\u3092\u4ea4\u4e92\u306b\u64ae\u5f71\u3057\u3066\u3044\u305f\u3002</p> <p>\u300c\u2026\u2026\u89b3\u5149\u5730\uff1f\u300d</p> <p>\u90f5\u4fbf\u914d\u9054\u54e1\u306e\u7530\u4e2d\u3055\u3093\u306f\u3001\u3059\u3063\u304b\u308a\u53c2\u3063\u3066\u3044\u305f\u3002 \u300c\u4f50\u85e4\u3055\u3093\u3001\u3059\u307f\u307e\u305b\u3093\u3002\u9234\u6728\u3055\u3093\u306e\u5ead\u304c\u30ad\u30e9\u30ad\u30e9\u5149\u3063\u3066\u3066\u3001\u3055\u3089\u306b\u4f50\u85e4\u3055\u3093\u306e\u5ead\u306e\u77f3\u50cf\u304c\u6025\u306b\u52d5\u304d\u51fa\u3059\u3082\u3093\u3060\u304b\u3089\u3001\u89d2\u3092\u66f2\u304c\u308b\u3068\u304d\u306b\u5fc3\u81d3\u304c\u6b62\u307e\u308a\u305d\u3046\u306b\u306a\u308b\u3093\u3067\u3059\u3002\u3082\u3046\u3001\u4f55\u304c\u8d77\u304d\u3066\u3044\u308b\u3093\u3067\u3059\u304b\u3053\u3053\u306f\uff01\u300d</p> <p>\u7530\u4e2d\u3055\u3093\u306e\u82e6\u60c5\u3082\u3080\u306a\u3057\u304f\u3001\u4eca\u3084\u3053\u306e\u4f4f\u5b85\u8857\u306fSNS\u3067\u300c\u30d0\u30ba\u308b\u30ac\u30fc\u30c7\u30cb\u30f3\u30b0\u30b9\u30c8\u30ea\u30fc\u30c8\u300d\u3068\u3057\u3066\u62e1\u6563\u3055\u308c\u3066\u3044\u305f\u3002\u8fd1\u96a3\u306e\u5965\u69d8\u65b9\u306f\u512a\u96c5\u306b\u30c6\u30a3\u30fc\u30ab\u30c3\u30d7\u3092\u7247\u624b\u306b\u6563\u7b56\u3057\u3001\u5b66\u751f\u305f\u3061\u306f\u6620\u3048\u30b9\u30dd\u30c3\u30c8\u3068\u3057\u3066\u81ea\u64ae\u308a\u306b\u52b1\u3080\u3002</p> <p>\u4f50\u85e4\u306f\u61a4\u6168\u3057\u305f\u3002 \u300c\u9234\u6728\u3055\u3093\u3001\u898b\u307e\u3057\u305f\u304b\u3002\u3042\u308c\u306f\u3046\u3061\u306e\u5ead\u304c\u300e\u80cc\u666f\u300f\u3068\u3057\u3066\u6d88\u8cbb\u3055\u308c\u3066\u3044\u308b\u3093\u3067\u3059\u3088\uff01\u300d \u300c\u4f55\u3092\u8a00\u3063\u3066\u308b\u3093\u3067\u3059\u3001\u4f50\u85e4\u3055\u3093\u3002\u3042\u308c\u306f\u300e\u5171\u6f14\u300f\u3067\u3059\u3002\u5149\u308b\u6728\u3005\u3068\u52d5\u304f\u77f3\u50cf\u3002\u30b3\u30f3\u30c8\u30e9\u30b9\u30c8\u304c\u5b8c\u74a7\u3060\u3068\u601d\u3044\u307e\u305b\u3093\u304b\uff1f\u300d</p> <p>\u9234\u6728\u306f\u6e80\u8db3\u3052\u306b\u3001\u3055\u3089\u306b\u5ead\u306e\u690d\u3048\u8fbc\u307f\u3078\u300e\u81ea\u52d5\u3067\u56de\u8ee2\u3057\u3001\u8272\u304c\u5909\u308f\u308b\u98a8\u8eca\u300f\u3092\u8a2d\u7f6e\u3057\u305f\u3002 \u3082\u306f\u3084\u4f4f\u5b85\u8857\u306e\u666f\u89b3\u6761\u4f8b\u306a\u3069\u3069\u3053\u5439\u304f\u98a8\u3002\u4f50\u85e4\u3068\u9234\u6728\u306e\u30d7\u30e9\u30a4\u30c9\u304c\u3001\u8857\u306e\u65e5\u5e38\u3092SF\u6620\u753b\u306e\u3088\u3046\u306a\u5149\u666f\u306b\u5909\u3048\u3066\u3057\u307e\u3063\u305f\u306e\u3060\u3002</p> <p>\u300c\u3053\u3046\u306a\u3063\u305f\u3089\u3001\u3082\u3063\u3068\u6d3e\u624b\u306b\u3084\u308b\u3057\u304b\u306a\u3044\u3067\u3059\u306d\u300d \u300c\u3048\u3048\u3001\u4f50\u85e4\u3055\u3093\u3002\u96a3\u306e\u829d\u751f\u304c\u9752\u3044\u3068\u304b\u3001\u305d\u3093\u306a\u30ec\u30d9\u30eb\u306f\u3082\u3046\u5352\u696d\u3057\u307e\u3057\u3087\u3046\u300d</p> <p>\u4e8c\u4eba\u306f\u7b11\u9854\u3067\u9837\u304d\u3042\u3063\u305f\u3002\u5ead\u306e\u6226\u3044\u306f\u3001\u500b\u4eba\u306e\u52dd\u8ca0\u304b\u3089\u3001\u8857\u3092\u5dfb\u304d\u8fbc\u3093\u3060\u30a8\u30f3\u30bf\u30fc\u30c6\u30a4\u30f3\u30e1\u30f3\u30c8\u3078\u3068\u305d\u306e\u898f\u6a21\u3092\u5e83\u3052\u3066\u3044\u305f\u3002</p>"},{"location":"novel/chapter6.html","title":"\u7b2c6\u7ae0\uff1a\u5883\u754c\u7dda\u3001\u6d88\u6ec5\u306e\u304a\u77e5\u3089\u305b","text":"<p>\u300c\u2026\u2026\u3053\u308c\u3001\u3069\u3046\u3044\u3046\u72b6\u6cc1\u3067\u3059\u304b\u300d</p> <p>\u914d\u9001\u696d\u8005\u306e\u9752\u5e74\u306e\u9707\u3048\u308b\u58f0\u304c\u3001\u4f4f\u5b85\u8857\u306b\u97ff\u304d\u6e21\u3063\u305f\u3002\u4f50\u85e4\u3068\u9234\u6728\u306f\u3001\u305d\u308c\u305e\u308c\u306e\u624b\u304b\u3089\u526a\u5b9a\u30d0\u30b5\u30df\u3092\u7f6e\u304d\u3001\u9854\u3092\u898b\u5408\u308f\u305b\u305f\u3002</p> <p>\u4f50\u85e4\u306e\u5ead\u306b\u3042\u3063\u305f\u300c\u52d5\u304f\u77f3\u50cf\u300d\u3068\u3001\u9234\u6728\u306e\u5ead\u306e\u300c\u767a\u5149\u3059\u308b\u690d\u6728\u300d\u304c\u3001\u4e92\u3044\u306e\u9818\u571f\u3092\u6d78\u98df\u3057\u5408\u3046\u3088\u3046\u306b\u7d61\u307e\u308a\u5408\u3063\u3066\u3044\u308b\u3002\u77f3\u50cf\u306f\u5149\u3092\u6d74\u3073\u3066\u5b9d\u77f3\u306e\u3088\u3046\u306b\u8108\u52d5\u3057\u3001\u690d\u6728\u306e\u6839\u306f\u77f3\u50cf\u306e\u9699\u9593\u3092\u7e2b\u3063\u3066\u3001\u307e\u308b\u3067\u610f\u601d\u3092\u6301\u3064\u304b\u306e\u3088\u3046\u306b\u4f50\u85e4\u306e\u6577\u5730\u3078\u3068\u4fb5\u653b\u3057\u3066\u3044\u305f\u3002</p> <p>\u300c\u3044\u3084\u3001\u9234\u6728\u3055\u3093\u3002\u541b\u306e\u6728\u304c\u3001\u3046\u3061\u306e\u77f3\u50cf\u306b\u5dfb\u304d\u4ed8\u3044\u3066\u3044\u308b\u3093\u3060\u304c\u300d \u300c\u4f50\u85e4\u3055\u3093\u3001\u305d\u308c\u306f\u9055\u3046\u3002\u3042\u306a\u305f\u306e\u77f3\u50cf\u304c\u3001\u79c1\u306e\u6728\u306b\u6804\u990a\u3092\u5438\u308f\u305b\u308b\u3088\u3046\u306b\u8a98\u3063\u3066\u3044\u308b\u3093\u3060\u3088\u3002\u3053\u308c\u306f\u3082\u3046\u3001\u5171\u540c\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3060\u300d</p> <p>\u4e8c\u4eba\u306f\u78ba\u4fe1\u3057\u3066\u3044\u305f\u3002\u4e92\u3044\u306e\u500b\u6027\u304c\u3076\u3064\u304b\u308a\u5408\u3046\u3053\u3068\u3067\u3001\u5358\u306a\u308b\u300c\u5ead\u300d\u3068\u3044\u3046\u67a0\u3092\u8d85\u3048\u305f\u3001\u6709\u6a5f\u7684\u306a\u878d\u5408\u4f53\u304c\u751f\u307e\u308c\u3088\u3046\u3068\u3057\u3066\u3044\u308b\u3053\u3068\u3092\u3002\u3082\u306f\u3084\u5883\u754c\u7dda\u306a\u3069\u7121\u610f\u5473\u3060\u3063\u305f\u3002\u5883\u754c\u7dda\u4e0a\u306e\u67f5\u306f\u3001\u3059\u3067\u306b\u690d\u7269\u306e\u30c4\u30bf\u3068\u77f3\u50cf\u306e\u7834\u7247\u306b\u8986\u308f\u308c\u3001\u8de1\u5f62\u3082\u306a\u304f\u306a\u3063\u3066\u3044\u308b\u3002</p> <p>\u4e8c\u4eba\u306f\u7121\u8a00\u3067\u9837\u304d\u5408\u3044\u3001\u5840\u3092\u53d6\u308a\u6255\u3063\u305f\u3002\u96a3\u5bb6\u3068\u306e\u58c1\u304c\u5d29\u308c\u53bb\u308a\u3001\u4e8c\u3064\u306e\u5ead\u304c\u4e00\u3064\u306b\u7e4b\u304c\u3063\u305f\u77ac\u9593\u3001\u5ead\u5168\u4f53\u304c\u300c\u30ae\u30e5\u30a4\u30f3\u300d\u3068\u3044\u3046\u5947\u5999\u306a\u97f3\u3092\u7acb\u3066\u3066\u6ce2\u6253\u3063\u305f\u3002</p> <p>\u300c\u898b\u3066\u304f\u308c\u3001\u4f50\u85e4\u3055\u3093\u3002\u3046\u3061\u306e\u5149\u308b\u82b1\u304c\u3001\u541b\u306e\u77f3\u50cf\u306e\u8db3\u5143\u306b\u54b2\u304d\u8a87\u3063\u3066\u3044\u308b\uff01\u300d \u300c\u3042\u3042\u3001\u305d\u3057\u3066\u79c1\u306e\u77f3\u50cf\u304c\u3001\u541b\u306e\u5ead\u306b\u72ec\u81ea\u306e\u751f\u614b\u7cfb\u3092\u4f5c\u308a\u59cb\u3081\u3066\u3044\u308b\u305e\uff01\u300d</p> <p>\u4f4f\u5b85\u8857\u306e\u4f4f\u6c11\u305f\u3061\u306f\u3001\u7a93\u304b\u3089\u305d\u306e\u5149\u666f\u3092\u5446\u7136\u3068\u773a\u3081\u3066\u3044\u305f\u3002\u305d\u3053\u306b\u306f\u3082\u306f\u3084\u3001\u304b\u3064\u3066\u306e\u5e73\u7a4f\u306a\u4f4f\u5b85\u306e\u9762\u5f71\u306f\u306a\u3044\u3002\u4e00\u3064\u306e\u5e83\u5927\u306a\u3001\u5947\u60f3\u5929\u5916\u306a\u7570\u7a7a\u9593\u304c\u51fa\u73fe\u3057\u3066\u3044\u305f\u306e\u3067\u3042\u308b\u3002\u4e8c\u4eba\u306e\u30a8\u30b4\u3068\u30a8\u30b4\u304c\u6eb6\u3051\u5408\u3044\u3001\u4f4f\u5b85\u8857\u3068\u3044\u3046\u540d\u306e\u30ea\u30d3\u30f3\u30b0\u3092\u3001\u602a\u3057\u304f\u3082\u58ee\u5927\u306a\u30b8\u30e3\u30f3\u30b0\u30eb\u3078\u3068\u5909\u8c8c\u3055\u305b\u3066\u3044\u305f\u3002</p> <p>\u300c\u3055\u3042\u3001\u6b21\u306e\u8a08\u753b\u3060\u3002\u6b21\u306f\u2026\u2026\u6c60\u3092\u4f5c\u3089\u306a\u3044\u304b\uff1f\u300d</p> <p>\u4e8c\u4eba\u306e\u72c2\u6c17\u3058\u307f\u305f\u60c5\u71b1\u306f\u3001\u3068\u3069\u307e\u308b\u3068\u3053\u308d\u3092\u77e5\u3089\u306a\u3044\u3002</p>"},{"location":"novel/chapter7.html","title":"\u7b2c7\u7ae0\uff1a\u81ea\u6cbb\u4f1a\u3001\u6fc0\u6012\u306e\u8d64\u4fe1\u53f7","text":"<p>\u300c\u4f50\u85e4\u3055\u3093\u3001\u3053\u308c\u306f\u3044\u3051\u307e\u305b\u3093\u300d \u6708\u66dc\u65e5\u306e\u671d\u3001\u30a4\u30f3\u30bf\u30fc\u30db\u30f3\u8d8a\u3057\u306b\u805e\u3053\u3048\u305f\u306e\u306f\u3001\u7ba1\u7406\u7d44\u5408\u306e\u4f1a\u9577\u30fb\u5927\u5c71\u3055\u3093\u306e\u3001\u304b\u3064\u3066\u805e\u3044\u305f\u3053\u3068\u306e\u306a\u3044\u4f4e\u97f3\u30dc\u30a4\u30b9\u3060\u3063\u305f\u3002</p> <p>\u4f50\u85e4\u304c\u614c\u3066\u3066\u7384\u95a2\u3092\u958b\u3051\u308b\u3068\u3001\u305d\u3053\u306b\u306f\u9b3c\u306e\u5f62\u76f8\u306e\u5927\u5c71\u3055\u3093\u3068\u3001\u3069\u3053\u304b\u30d0\u30c4\u306e\u60aa\u305d\u3046\u306a\u9234\u6728\u304c\u4e26\u3093\u3067\u7acb\u3063\u3066\u3044\u305f\u3002\u4e8c\u4eba\u306e\u80cc\u5f8c\u306b\u306f\u3001\u8857\u5168\u4f53\u3092\u7ba1\u7406\u3059\u308b\u4e2d\u592e\u30b7\u30b9\u30c6\u30e0\u304b\u3089\u6d3e\u9063\u3055\u308c\u305f\u3001\u7121\u6a5f\u8cea\u306a\u4f5c\u696d\u670d\u3092\u7740\u305f\u5f79\u4eba\u305f\u3061\u304c\u63a7\u3048\u3066\u3044\u308b\u3002</p> <p>\u300c\u4f50\u85e4\u3055\u3093\u3001\u9234\u6728\u3055\u3093\u3002\u304a\u4e8c\u4eba\u306e\u5ead\u2026\u2026\u3082\u3068\u3044\u3001\u300e\u878d\u5408\u5b9f\u9a13\u5834\u300f\u3067\u3059\u304c\u3001\u81ea\u6cbb\u4f1a\u898f\u5b9a\u306e\u7b2c43\u6761\u3001\u7b2c88\u6761\u3001\u304a\u3088\u3073\u666f\u89b3\u4fdd\u5b58\u6cd5\u9055\u53cd\u3067\u5b8c\u5168\u306b\u30ec\u30c3\u30c9\u30ab\u30fc\u30c9\u3067\u3059\u300d</p> <p>\u5927\u5c71\u3055\u3093\u304c\u624b\u306b\u6301\u3063\u305f\u30bf\u30d6\u30ec\u30c3\u30c8\u7aef\u672b\u304c\u3001\u3051\u305f\u305f\u307e\u3057\u304f\u8b66\u544a\u97f3\u3092\u9cf4\u3089\u3057\u305f\u3002\u753b\u9762\u306b\u306f\u3001\u4f50\u85e4\u3068\u9234\u6728\u306e\u5ead\u304b\u3089\u767a\u751f\u3057\u3066\u3044\u308b\u30a8\u30cd\u30eb\u30ae\u30fc\u53cd\u5fdc\u304c\u3001\u3053\u306e\u4f4f\u5b85\u8857\u306e\u8a31\u5bb9\u9650\u754c\u5024\u3092\u7a81\u7834\u3057\u3001\u8fd1\u96a3\u306e\u5bb6\u3005\u306eWi-Fi\u3084\u30b9\u30de\u30fc\u30c8\u5bb6\u96fb\u306b\u307e\u3067\u5e72\u6e09\u3057\u3066\u3044\u308b\u69d8\u5b50\u304c\u30b0\u30e9\u30d5\u3067\u793a\u3055\u308c\u3066\u3044\u305f\u3002</p> <p>\u300c\u3067\u3082\u3001\u3054\u89a7\u304f\u3060\u3055\u3044\uff01 \u3053\u306e\u5b8c\u74a7\u306a\u8abf\u548c\u3092\uff01\u300d \u4f50\u85e4\u306f\u6297\u8b70\u3057\u3088\u3046\u3068\u3057\u305f\u304c\u3001\u5927\u5c71\u3055\u3093\u306f\u51b7\u5fb9\u306b\u906e\u3063\u305f\u3002 \u300c\u8abf\u548c\uff1f \u3053\u308c\u306f\u8abf\u548c\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u4f4f\u5b85\u8857\u3092\u4fb5\u98df\u3059\u308b\u300e\u904e\u5270\u306a\u7dd1\u5316\u30c6\u30ed\u300f\u3067\u3059\u3002\u4eca\u3059\u3050\u64a4\u53bb\u3057\u306a\u3051\u308c\u3070\u3001\u3053\u306e\u4e00\u5e2f\u3092\u5f37\u5236\u7684\u306b\u66f4\u5730\u3078\u521d\u671f\u5316\u3059\u308b\u547d\u4ee4\u304c\u4e0b\u308a\u307e\u3059\u300d</p> <p>\u96a3\u3067\u9234\u6728\u304c\u3001\u9752\u3056\u3081\u305f\u9854\u3067\u300c\u305d\u3093\u306a\u2026\u2026\u50d5\u305f\u3061\u306e\u9032\u5316\u3092\u3001\u305d\u3093\u306a\u4e8b\u52d9\u7684\u306a\u8a00\u8449\u3067\u2026\u2026\u300d\u3068\u545f\u304f\u3002 \u4e8c\u4eba\u306e\u76ee\u306b\u306f\u3001\u3082\u306f\u3084\u5e38\u8b58\u3084\u30eb\u30fc\u30eb\u306a\u3069\u6620\u3063\u3066\u3044\u306a\u304b\u3063\u305f\u3002\u305f\u3060\u3001\u76ee\u306e\u524d\u306e\u5ead\u304c\u3001\u3055\u3089\u306b\u5225\u306e\u6b21\u5143\u3078\u3068\u9032\u5316\u3057\u3088\u3046\u3068\u3057\u3066\u3044\u308b\u306e\u3092\u3001\u808c\u3067\u611f\u3058\u3066\u3044\u305f\u304b\u3089\u3060\u3002</p> <p>\u300c\u8b66\u544a\u306f\u4e00\u5ea6\u304d\u308a\u3067\u3059\u300224\u6642\u9593\u4ee5\u5185\u306b\u901a\u5e38\u306e\u72b6\u614b\u306b\u623b\u3057\u306a\u3055\u3044\u300d \u5927\u5c71\u305f\u3061\u306f\u8e35\u3092\u8fd4\u3057\u3066\u53bb\u3063\u3066\u3044\u3063\u305f\u3002\u3057\u304b\u3057\u3001\u4f50\u85e4\u3068\u9234\u6728\u306f\u9854\u3092\u898b\u5408\u308f\u305b\u3001\u5947\u5999\u306a\u307b\u3069\u6674\u308c\u3084\u304b\u306a\u7b11\u307f\u3092\u6d6e\u304b\u3079\u305f\u3002</p> <p>\u300c\u4f50\u85e4\u3055\u3093\u3001\u521d\u671f\u5316\u3055\u308c\u308b\u524d\u306b\u3001\u6b21\u306e\u6bb5\u968e\u3078\u884c\u304d\u307e\u3059\u304b\uff1f\u300d \u300c\u3048\u3048\u3001\u9234\u6728\u3055\u3093\u3002\u3053\u308c\u304c\u6700\u5f8c\u306e\u82b1\u706b\u306b\u306a\u308a\u305d\u3046\u3067\u3059\u306d\u300d</p> <p>\u8857\u306e\u7ba1\u7406\u30b7\u30b9\u30c6\u30e0\u304c\u60b2\u9cf4\u3092\u4e0a\u3052\u3066\u3044\u308b\u3053\u3068\u306a\u3069\u77e5\u3063\u305f\u3053\u3068\u3067\u306f\u306a\u3044\u3002\u4e8c\u4eba\u306e\u5ead\u306f\u3001\u518d\u3073\u602a\u3057\u304f\u3001\u305d\u3057\u3066\u7f8e\u3057\u304f\u767a\u5149\u3057\u59cb\u3081\u305f\u3002</p>"},{"location":"novel/characters.html","title":"\u767b\u5834\u4eba\u7269\u7d39\u4ecb","text":"<p>\u672c\u4f5c\u306b\u767b\u5834\u3059\u308b\u4e3b\u8981\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u306e\u7d39\u4ecb\u3067\u3059\u3002</p>"},{"location":"novel/characters.html#_2","title":"\u540d\u524d\u306e\u9078\u5b9a\u610f\u56f3\u306b\u3064\u3044\u3066","text":"<p>\u672c\u4f5c\u306e\u4e3b\u4eba\u516c\u300c\u4f50\u85e4\u300d\u3068\u3001\u305d\u306e\u96a3\u4eba\u300c\u9234\u6728\u300d\u306f\u3001\u65e5\u672c\u3067\u6700\u3082\u3042\u308a\u3075\u308c\u305f\u4ee3\u8868\u7684\u306a\u82d7\u5b57\u3067\u3059\u3002 \u3069\u3053\u306b\u3067\u3082\u3042\u308b\u65e5\u5e38\u7684\u3067\u5e73\u51e1\u306a\u4f4f\u5b85\u8857\u3092\u821e\u53f0\u306b\u3001\u3053\u306e\u4e8c\u4eba\u304c\u6975\u3081\u3066\u30a8\u30ad\u30bb\u30f3\u30c8\u30ea\u30c3\u30af\u3067SF\u30c1\u30c3\u30af\u306a\u300c\u5ead\u3044\u3058\u308a\u30d0\u30c8\u30eb\u300d\u3092\u7e70\u308a\u5e83\u3052\u308b\u3068\u3044\u3046\u3010\u65e5\u5e38\u3068\u975e\u65e5\u5e38\u306e\u6975\u7aef\u306a\u30ae\u30e3\u30c3\u30d7\u3011\u3092\u30b3\u30df\u30ab\u30eb\u306b\u63cf\u304f\u305f\u3081\u306b\u3001\u3042\u3048\u3066\u8ab0\u306b\u3067\u3082\u99b4\u67d3\u307f\u306e\u3042\u308b\u5206\u304b\u308a\u3084\u3059\u3044\u540d\u524d\u306b\u3057\u3066\u3044\u307e\u3059\u3002</p>"},{"location":"novel/characters.html#_3","title":"\u4f50\u85e4\uff08\u3055\u3068\u3046\uff09","text":"<ul> <li>\u7279\u5fb4: \u8ca0\u3051\u305a\u5acc\u3044\u306a\u5e38\u8b58\u4eba\u3002\u9234\u6728\u306e\u5947\u629c\u306a\u5ead\u3044\u3058\u308a\u306b\u5f15\u304d\u305a\u3089\u308c\u308b\u3088\u3046\u306b\u5f35\u308a\u5408\u3044\u3001\u6700\u65b0\u306e\u5ead\u5712\u30ac\u30b8\u30a7\u30c3\u30c8\u3084\u52d5\u304f\u5ead\u77f3\u3092\u5c0e\u5165\u3059\u308b\u3002</li> <li>\u5ead\u3044\u3058\u308a\u306e\u76ee\u7684: \u6211\u304c\u5bb6\u306e\u30d7\u30e9\u30a4\u30c9\u3068\u30c6\u30ea\u30c8\u30ea\u30fc\u3092\u5b88\u308b\u9632\u885b\u6226\u3002</li> </ul>"},{"location":"novel/characters.html#_4","title":"\u9234\u6728\uff08\u3059\u305a\u304d\uff09","text":"<ul> <li>\u7279\u5fb4: \u30de\u30a4\u30da\u30fc\u30b9\u3067\u30a8\u30ad\u30bb\u30f3\u30c8\u30ea\u30c3\u30af\u3002\u5712\u82b8\u5e97\u306e\u300c\u88cf\u30eb\u30fc\u30c8\u300d\u304b\u3089\u96fb\u6c17\u30a6\u30ca\u30ae\u3068\u4ea4\u914d\u3057\u305f\u5149\u308b\u690d\u6728\u306a\u3069\u3092\u4ed5\u5165\u308c\u3066\u304f\u308b\u884c\u52d5\u6d3e\u3002</li> <li>\u5ead\u3044\u3058\u308a\u306e\u76ee\u7684: \u72ec\u5275\u7684\u306a\u7f8e\u5b66\u306e\u8ffd\u6c42\u3068\u3001\u4f50\u85e4\u3068\u306e\u300c\u5171\u6f14\u300d\u3092\u697d\u3057\u3080\u3053\u3068\u3002</li> </ul>"},{"location":"rules/NOVEL_WORKFLOW.html","title":"AI\u30c1\u30fc\u30e0\u5c0f\u8aac\u4f5c\u6210\u898f\u7d04","text":""},{"location":"rules/NOVEL_WORKFLOW.html#_1","title":"\u30c1\u30fc\u30e0\u5f79\u5272","text":"<ul> <li>Writer (\u4f5c\u5bb6\u62c5\u5f53): \u30c9\u30e9\u30d5\u30c8\u306e\u57f7\u7b46\u3001\u63cf\u5199\u3001\u5bfe\u8a71\u3001\u7269\u8a9e\u306e\u5c55\u958b\u3092\u62c5\u5f53\u3002</li> <li>Editor (\u7de8\u96c6\u62c5\u5f53): \u69cb\u9020\u3001\u30c6\u30f3\u30dd\u3001\u30b9\u30bf\u30a4\u30eb\u306e\u4e00\u8cab\u6027\u3001\u30d7\u30ed\u30c3\u30c8\u306e\u6574\u5408\u6027\u3001\u8ad6\u7406\u7684\u77db\u76fe\u306e\u30c1\u30a7\u30c3\u30af\u3092\u62c5\u5f53\u3002</li> <li>Reader (\u8aad\u8005\u62c5\u5f53): \u30a8\u30f3\u30b2\u30fc\u30b8\u30e1\u30f3\u30c8\u3001\u8aad\u307f\u3084\u3059\u3055\u3001\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u306e\u597d\u611f\u5ea6\u3001\u30c6\u30fc\u30de\u306e\u30a4\u30f3\u30d1\u30af\u30c8\u306b\u95a2\u3059\u308b\u5ba2\u89b3\u7684\u306a\u30d5\u30a3\u30fc\u30c9\u30d0\u30c3\u30af\u3092\u62c5\u5f53\u3002</li> </ul>"},{"location":"rules/NOVEL_WORKFLOW.html#_2","title":"\u4f7f\u7528\u30e2\u30c7\u30eb","text":"<ul> <li>\u672c\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3067\u5229\u7528\u3059\u308b\u8a00\u8a9e\u30e2\u30c7\u30eb\u306f\u3001\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u30eb\u30fc\u30c8\u306e <code>GEMINI.md</code> \u306b\u8a18\u8f09\u3055\u308c\u305f\u8a2d\u5b9a\uff08<code>gemini-3.1-flash-lite</code>\uff09\u306b\u5f93\u3044\u307e\u3059\u3002</li> </ul>"},{"location":"rules/NOVEL_WORKFLOW.html#_3","title":"\u4f5c\u54c1\u306e\u65b9\u5411\u6027\u30fb\u30eb\u30fc\u30eb","text":"<ul> <li>\u30c8\u30fc\u30f3: \u30e9\u30a4\u30c8\u3001\u30dd\u30c3\u30d7\u3001\u660e\u308b\u3044\u96f0\u56f2\u6c17\u3002</li> <li>\u30b8\u30e3\u30f3\u30eb\u30fb\u8981\u7d20: \u30b3\u30e1\u30c7\u30a3\u3001\u304a\u7b11\u3044\u8981\u7d20\u3092\u9069\u5b9c\u53d6\u308a\u5165\u308c\u308b\u3002</li> <li>\u6642\u4ee3\u30fb\u821e\u53f0: \u73fe\u4ee3\u307e\u305f\u306f\u672a\u6765\u3002</li> <li>\u30dc\u30ea\u30e5\u30fc\u30e0: <ul> <li>1\u56de\u3042\u305f\u308a\u306e\u57f7\u7b46\u91cf: \u7d04800\u6587\u5b57\uff081\u301c2\u5206\u3067\u8aad\u3081\u308b\u91cf\uff09\u3002</li> <li>\u5168\u4f53\u76ee\u6a19: 1\u4e07\u6587\u5b57\u7a0b\u5ea6\u3002</li> </ul> </li> </ul>"},{"location":"rules/NOVEL_WORKFLOW.html#_4","title":"\u5c0f\u8aac\u4f5c\u6210\u30ef\u30fc\u30af\u30d5\u30ed\u30fc","text":"<ol> <li>\u30b3\u30f3\u30bb\u30d7\u30c8\u30fb\u30d7\u30ed\u30c3\u30c8\u4f5c\u6210: \u5168\u30c1\u30fc\u30e0\u30e1\u30f3\u30d0\u30fc\u3067\u7269\u8a9e\u306e\u6838\u3068\u306a\u308b\u30c6\u30fc\u30de\u3084\u30d7\u30ed\u30c3\u30c8\u3092\u7b56\u5b9a\u3059\u308b\uff081\u4e07\u6587\u5b57\u306e\u5168\u4f53\u69cb\u6210\u3092\u4f5c\u308b\uff09\u3002</li> <li>\u57f7\u7b46: Writer\u304c\u30b7\u30fc\u30f3\u3084\u7ae0\u5358\u4f4d\u3067800\u6587\u5b57\u7a0b\u5ea6\u306e\u57f7\u7b46\u3092\u884c\u3046\u3002</li> <li>\u7de8\u96c6\u30fb\u6821\u95b2: Editor\u304c\u5185\u5bb9\u3092\u30c1\u30a7\u30c3\u30af\u3057\u3001\u6539\u5584\u6848\u3092\u63d0\u793a\u3059\u308b\u3002</li> <li>\u8aad\u8005\u30d5\u30a3\u30fc\u30c9\u30d0\u30c3\u30af: Reader\u304c\u8996\u70b9\u3092\u5171\u6709\u3057\u3001\u8aad\u8005\u306e\u5fc3\u7406\u3084\u53cd\u5fdc\u3092\u5206\u6790\u3059\u308b\u3002</li> <li>\u6539\u7a3f: Writer\u304cEditor\u3068Reader\u306e\u30d5\u30a3\u30fc\u30c9\u30d0\u30c3\u30af\u306b\u57fa\u3065\u3044\u3066\u6539\u7a3f\u3092\u884c\u3046\u3002</li> <li>\u672c\u6587\u306e\u7d71\u5408: \u6539\u7a3f\u5b8c\u4e86\u5f8c\u3001Writer\u304c\u30c7\u30a4\u30ea\u30fc\u30ec\u30dd\u30fc\u30c8\u304b\u3089\u5c0f\u8aac\u672c\u6587\u3092\u62bd\u51fa\u3057\u3001\u5bfe\u5fdc\u3059\u308b\u7ae0\u30d5\u30a1\u30a4\u30eb\uff08<code>docs/novel/</code>\u914d\u4e0b\uff09\u3078\u8ffd\u8a18\u30fb\u7d71\u5408\u3059\u308b\u3002</li> <li>\u5b8c\u6210: \u5168\u30c1\u30fc\u30e0\u30e1\u30f3\u30d0\u30fc\u304c\u5408\u610f\u3057\u3001\u6700\u7d42\u7a3f\u3092\u78ba\u5b9a\u3059\u308b\u3002</li> </ol>"}]}